<Window x:Class="Esp32Controller.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Esp32Controller.Views"
        mc:Ignorable="d"
        Title="Serial Switch Controller" Height="650" Width="500">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- COM Port 區 -->
            <RowDefinition Height="Auto"/>
            <!-- 狀態訊息 -->
            <RowDefinition Height="Auto"/>
            <!-- LED 控制標題 -->
            <RowDefinition Height="Auto"/>
            <!-- 快捷按鈕 -->
            <RowDefinition Height="Auto"/>
            <!-- 自訂顏色標題 -->
            <RowDefinition Height="Auto"/>
            <!-- 自訂顏色輸入區 -->
            <RowDefinition Height="Auto"/>
            <!-- LED 狀態顯示 -->
            <RowDefinition Height="Auto"/>
            <!-- 通訊紀錄標題 -->
            <RowDefinition Height="*"/>
            <!-- 通訊紀錄列表 -->
            <RowDefinition Height="Auto"/>
            <!-- 清除按鈕 -->
        </Grid.RowDefinitions>

        <!-- COM Port 選擇 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="COM Port:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <ComboBox ItemsSource="{Binding AvailablePorts}"
              SelectedItem="{Binding SelectedPort}"
              Width="120" Margin="0,0,5,0"/>
            <Button Content="🔄" 
            Command="{Binding RefreshPortsCommand}"
            Width="30" Margin="0,0,10,0"
            ToolTip="重新整理 COM Port 清單"/>
            <Button Content="連線"
            Command="{Binding ConnectCommand}"
            Width="60" Margin="0,0,5,0"/>
            <Button Content="中斷"
            Command="{Binding DisconnectCommand}"
            Width="60"/>
        </StackPanel>

        <!-- 狀態訊息 -->
        <TextBlock Grid.Row="1"
                   Text="{Binding StatusMessage}"
                   FontSize="14"
                   Margin="0,0,0,20"/>

        <!-- LED 控制標題 -->
        <TextBlock Grid.Row="2"
                   Text="LED 控制（快捷）"
                   FontSize="16" FontWeight="Bold"
                   Margin="0,0,0,5"/>

        <!-- 快捷按鈕 -->
        <WrapPanel Grid.Row="3" Margin="0,0,0,15">
            <Button Content="開啟" Command="{Binding TurnOnCommand}" Width="60" Height="35" Margin="0,0,5,5"/>
            <Button Content="關閉" Command="{Binding TurnOffCommand}" Width="60" Height="35" Margin="0,0,5,5"/>
            <Button Content="RGB 循環" Command="{Binding SetRgbCycleCommand}" Width="80" Height="35" Margin="0,0,5,5"/>
        </WrapPanel>

        <!-- 自訂顏色標題 -->
        <TextBlock Grid.Row="4"
                   Text="自訂顏色（RGB）"
                   FontSize="16" FontWeight="Bold"
                   Margin="0,0,0,5"/>

        <!-- 自訂顏色輸入區 -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="R:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Text="{Binding CustomR}" Width="50" Margin="0,0,10,0"/>
            <TextBlock Text="G:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Text="{Binding CustomG}" Width="50" Margin="0,0,10,0"/>
            <TextBlock Text="B:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Text="{Binding CustomB}" Width="50" Margin="0,0,10,0"/>
            <Button Content="套用" Command="{Binding ApplyCustomColorCommand}" Width="60" Height="25"/>
        </StackPanel>

        <!-- LED 狀態顯示 -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="LED 狀態: " VerticalAlignment="Center"/>
            <Ellipse Width="20" Height="20"
                     Fill="{Binding LedColor}"
                     Stroke="Black" StrokeThickness="1"
                     Margin="5,0"/>
            <TextBlock Text="{Binding LedState}" VerticalAlignment="Center" FontWeight="Bold"/>
        </StackPanel>

        <!-- 通訊紀錄標題 -->
        <TextBlock Grid.Row="7"
                   Text="通訊紀錄"
                   FontSize="16" FontWeight="Bold"
                   Margin="0,0,0,5"/>

        <!-- 通訊紀錄列表 -->
        <ListBox Grid.Row="8"
                 ItemsSource="{Binding CommunicationLogs}"
                 FontFamily="Consolas"
                 FontSize="12"
                 Margin="0,0,0,10"/>

        <!-- 清除按鈕 -->
        <Button Grid.Row="9"
                Content="清除紀錄"
                Command="{Binding ClearLogsCommand}"
                HorizontalAlignment="Left"
                Width="80" Height="30"/>
    </Grid>
</Window>